{
  "name": "hermes-ollama-vscode",
  "displayName": "Ollama Hermes Agent",
  "description": "Chat with Hermes Agent in VS Code via Ollama. Uses ACP protocol — full agent with tools, memory, and skills.",
  "version": "0.7.2",
  "publisher": "Natadel",
  "icon": "media/icon.png",
  "repository": "https://github.com/zdenkor/hermes-ollama-vscode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "hermes",
    "agent",
    "ai",
    "acp",
    "ollama"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes",
          "title": "Hermes",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "hermes": [
        {
          "id": "hermes-chat",
          "name": "Chat",
          "type": "webview",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "hermes.send",
        "title": "Hermes: Send Prompt"
      },
      {
        "command": "hermes.cancel",
        "title": "Hermes: Cancel Turn",
        "icon": "$(debug-stop)"
      },
      {
        "command": "hermes.newSession",
        "title": "Hermes: New Session",
        "icon": "$(add)"
      },
      {
        "command": "hermes.chooseModel",
        "title": "Hermes: Choose Model",
        "icon": "$(circuit-board)"
      },
      {
        "command": "hermes.sessions",
        "title": "Hermes: Sessions",
        "icon": "$(history)"
      },
      {
        "command": "hermes.restartAgent",
        "title": "Hermes: Restart Agent",
        "icon": "$(debug-restart)"
      },
      {
        "command": "hermes.setup",
        "title": "Hermes: Setup Wizard",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hermes.newSession",
          "when": "view == hermes-chat",
          "group": "navigation@1"
        },
        {
          "command": "hermes.chooseModel",
          "when": "view == hermes-chat",
          "group": "navigation@2"
        },
        {
          "command": "hermes.sessions",
          "when": "view == hermes-chat",
          "group": "navigation@3"
        },
        {
          "command": "hermes.cancel",
          "when": "view == hermes-chat",
          "group": "navigation@3"
        },
        {
          "command": "hermes.restartAgent",
          "when": "view == hermes-chat",
          "group": "navigation@4"
        },
        {
          "command": "hermes.setup",
          "when": "view == hermes-chat",
          "group": "navigation@5"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hermes.cancel",
        "key": "escape",
        "when": "hermes.turnInProgress"
      }
    ],
    "configuration": {
      "title": "Hermes",
      "properties": {
        "hermes.executable": {
          "type": "string",
          "default": "hermes",
          "description": "Path to the hermes executable. Leave as 'hermes' to find it in PATH."
        },
        "hermes.defaultCwd": {
          "type": "string",
          "default": "",
          "description": "Default working directory for agent sessions"
        },
        "hermes.logTraffic": {
          "type": "boolean",
          "default": true,
          "description": "Log ACP protocol traffic to output"
        },
        "hermes.model": {
          "type": "string",
          "default": "",
          "description": "Model to use (e.g. deepseek-v4-pro:cloud). Leave empty for default."
        },
        "hermes.modelList": {
          "type": "string",
          "default": "deepseek-v4-pro:cloud,deepseek-v4-pro:local,llama3.2:latest,qwen2.5:latest",
          "description": "Comma-separated list of available models for selection"
        },
        "hermes.apiServerUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8642",
          "description": "Hermes API server URL for fetching available models"
        },
        "hermes.apiServerKey": {
          "type": "string",
          "default": "",
          "description": "API server bearer token (set in User settings, not workspace)"
        },
        "hermes.useCopilotChat": {
          "type": "boolean",
          "default": false,
          "description": "Register Hermes as a Copilot Chat participant (@hermes)"
        },
        "hermes.safetyTimeout": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "Safety timeout in minutes. If the server stops responding, the UI resets after this duration."
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "hermes",
        "displayName": "Hermes Agent"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@types/events": "^3.0.3",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0"
  }
}
